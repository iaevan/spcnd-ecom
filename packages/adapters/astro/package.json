{
  "name": "@spacendigital/astro",
  "version": "0.1.0",
  "description": "Astro adapter for spcnd-ecom: API catch-all mount helper, SSR storefront helpers, and drop-in components",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./components/*": "./components/*"
  },
  "files": [
    "dist",
    "components"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@spacendigital/core": "workspace:*",
    "@spacendigital/types": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}