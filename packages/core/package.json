{
  "name": "@spacendigital/core",
  "version": "0.1.0",
  "description": "Framework-agnostic commerce engine for spcnd-ecom: entities, cart, checkout, orders, coupons, settings, i18n, SEO",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
