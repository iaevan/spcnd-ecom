  "dependencies": {
    "@spacendigital/db": "workspace:*",
    "@spacendigital/plugin-system": "workspace:*",
    "@spacendigital/types": "workspace:*",
    "drizzle-orm": "^0.44.2",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
